<div class="settings-container">
  <div class="settings-header">
    <a href="/profile" class="back-btn">
      <i class="bi bi-arrow-left"></i>
    </a>
    <h1 class="settings-title">Settings</h1>
  </div>

  <%- include('../partials/flash') %>

  <!-- ACCOUNT -->
  <p class="settings-section-label">ACCOUNT</p>

  <div class="settings-group">
    <a href="/settings/personal-info" class="settings-row">
      <div class="settings-row-left">
        <div class="settings-icon-wrap">
          <i class="bi bi-person-fill"></i>
        </div>
        <div class="settings-row-text">
          <span class="settings-row-title">Personal Information</span>
          <span class="settings-row-sub">Name, email, age, gender</span>
        </div>
      </div>
      <i class="bi bi-chevron-right settings-chevron"></i>
    </a>

    <a href="/settings/body-metrics" class="settings-row">
      <div class="settings-row-left">
        <div class="settings-icon-wrap">
          <i class="bi bi-rulers"></i>
        </div>
        <div class="settings-row-text">
          <span class="settings-row-title">Body metrics</span>
          <span class="settings-row-sub">Height, weight</span>
        </div>
      </div>
      <i class="bi bi-chevron-right settings-chevron"></i>
    </a>

    <a href="/settings/password" class="settings-row">
      <div class="settings-row-left">
        <div class="settings-icon-wrap">
          <i class="bi bi-lock-fill"></i>
        </div>
        <div class="settings-row-text">
          <span class="settings-row-title">Password &amp; security</span>
          <span class="settings-row-sub">Change password, 2FA</span>
        </div>
      </div>
      <i class="bi bi-chevron-right settings-chevron"></i>
    </a>
  </div>

  <!-- PREFERENCES -->
  <p class="settings-section-label">PREFERENCES</p>

  <div class="settings-group">
    <a href="/settings/notifications" class="settings-row">
      <div class="settings-row-left">
        <div class="settings-icon-wrap settings-icon-yellow">
          <i class="bi bi-bell-fill"></i>
        </div>
        <div class="settings-row-text">
          <span class="settings-row-title">Notifications</span>
          <span class="settings-row-sub">Reminders and updates</span>
        </div>
      </div>
      <i class="bi bi-chevron-right settings-chevron"></i>
    </a>

    <a href="/settings/goals" class="settings-row">
      <div class="settings-row-left">
        <div class="settings-icon-wrap settings-icon-red">
          <i class="bi bi-bullseye"></i>
        </div>
        <div class="settings-row-text">
          <span class="settings-row-title">Goals &amp; preferences</span>
          <span class="settings-row-sub">Workout goals, duration</span>
        </div>
      </div>
      <i class="bi bi-chevron-right settings-chevron"></i>
    </a>

    <a href="/settings/pain-management" class="settings-row">
      <div class="settings-row-left">
        <div class="settings-icon-wrap settings-icon-orange">
          <i class="bi bi-bandaid-fill"></i>
        </div>
        <div class="settings-row-text">
          <span class="settings-row-title">Pain management</span>
          <span class="settings-row-sub">Current pain areas</span>
        </div>
      </div>
      <i class="bi bi-chevron-right settings-chevron"></i>
    </a>
  </div>

  <!-- SUPPORT -->
  <p class="settings-section-label">SUPPORT</p>

  <div class="settings-group">
    <a href="/help" class="settings-row">
      <div class="settings-row-left">
        <div class="settings-icon-wrap settings-icon-red">
          <i class="bi bi-question-circle-fill"></i>
        </div>
        <div class="settings-row-text">
          <span class="settings-row-title">Help center</span>
        </div>
      </div>
      <i class="bi bi-chevron-right settings-chevron"></i>
    </a>
  </div>
</div>

<%- include('../partials/bottomNav') %>
