<div class="settings-container">
  <div class="settings-header">
    <a href="/settings" class="back-btn">
      <i class="bi bi-arrow-left"></i>
    </a>
    <h1 class="settings-title">Password &amp; security</h1>
  </div>

  <form action="/settings/password" method="POST">
    <div class="settings-form-card">

      <div class="settings-field">
        <label class="settings-label" for="currentPassword">Current password</label>
        <div class="settings-input-wrap">
          <input
            type="password"
            id="currentPassword"
            name="currentPassword"
            class="settings-input"
            placeholder="Enter current password"
            required
          >
          <button type="button" class="toggle-pw-btn" data-target="currentPassword">
            <i class="bi bi-eye"></i>
          </button>
        </div>
      </div>

      <div class="settings-field">
        <label class="settings-label" for="newPassword">New password</label>
        <div class="settings-input-wrap">
          <input
            type="password"
            id="newPassword"
            name="newPassword"
            class="settings-input"
            placeholder="At least 8 characters"
            minlength="8"
            required
          >
          <button type="button" class="toggle-pw-btn" data-target="newPassword">
            <i class="bi bi-eye"></i>
          </button>
        </div>
        <div class="pw-rules" id="pwRules">
          <p class="pw-rule" id="rule-length"><i class="bi bi-x-circle-fill"></i> At least 8 characters</p>
          <p class="pw-rule" id="rule-upper"><i class="bi bi-x-circle-fill"></i> One uppercase letter</p>
          <p class="pw-rule" id="rule-lower"><i class="bi bi-x-circle-fill"></i> One lowercase letter</p>
          <p class="pw-rule" id="rule-special"><i class="bi bi-x-circle-fill"></i> One special character (!@#$...)</p>
        </div>
      </div>

      <div class="settings-field settings-field--last">
        <label class="settings-label" for="confirmPassword">Confirm new password</label>
        <div class="settings-input-wrap">
          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            class="settings-input"
            placeholder="Repeat new password"
            minlength="8"
            required
          >
          <button type="button" class="toggle-pw-btn" data-target="confirmPassword">
            <i class="bi bi-eye"></i>
          </button>
        </div>
      </div>
    </div>

    <button type="submit" class="btn-settings-save">Update password</button>
  </form>

  <!-- 2FA row -->
  <p class="settings-section-label" style="margin-top:24px;">TWO-FACTOR AUTHENTICATION</p>
  <div class="settings-group">
    <a href="<%= user.twofaEnabled ? '/twofa/disable' : '/twofa/setup' %>" class="settings-row">
      <div class="settings-row-left">
        <div class="settings-icon-wrap">
          <i class="bi bi-shield-lock-fill"></i>
        </div>
        <div class="settings-row-text">
          <span class="settings-row-title"><%= user.twofaEnabled ? 'Disable 2FA' : 'Enable 2FA' %></span>
          <span class="settings-row-sub"><%= user.twofaEnabled ? 'Currently active' : 'Add extra security' %></span>
        </div>
      </div>
      <i class="bi bi-chevron-right settings-chevron"></i>
    </a>
  </div>
</div>

<%- include('../partials/bottomNav') %>

<script>
  // Password complexity rules
  const newPasswordInput = document.getElementById('newPassword');
  const rules = {
    'rule-length':  v => v.length >= 8,
    'rule-upper':   v => /[A-Z]/.test(v),
    'rule-lower':   v => /[a-z]/.test(v),
    'rule-special': v => /[!@#$%^&*(),.?":{}|<>]/.test(v),
  };

  newPasswordInput.addEventListener('input', () => {
    const v = newPasswordInput.value;
    Object.entries(rules).forEach(([id, test]) => {
      const el = document.getElementById(id);
      const icon = el.querySelector('i');
      if (test(v)) {
        el.classList.add('pw-rule--pass');
        icon.className = 'bi bi-check-circle-fill';
      } else {
        el.classList.remove('pw-rule--pass');
        icon.className = 'bi bi-x-circle-fill';
      }
    });
  });

  document.querySelectorAll('.toggle-pw-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const input = document.getElementById(btn.dataset.target);
      const icon = btn.querySelector('i');
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('bi-eye', 'bi-eye-slash');
      } else {
        input.type = 'password';
        icon.classList.replace('bi-eye-slash', 'bi-eye');
      }
    });
  });
</script>
