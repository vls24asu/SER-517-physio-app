<div class="settings-container">
  <div class="settings-header">
    <a href="/settings" class="back-btn">
      <i class="bi bi-arrow-left"></i>
    </a>
    <h1 class="settings-title">Body metrics</h1>
  </div>

  <%- include('../partials/flash') %>

  <form action="/settings/body-metrics" method="POST">
    <div class="settings-form-card">

      <div class="settings-field">
        <label class="settings-label" for="heightCm">Height (cm)</label>
        <input
          type="number"
          id="heightCm"
          name="heightCm"
          class="settings-input"
          value="<%= profile && profile.height_cm ? profile.height_cm : '' %>"
          placeholder="e.g. 175"
          min="50"
          max="300"
          step="0.1"
        >
      </div>

      <div class="settings-field settings-field--last">
        <label class="settings-label" for="weightKg">Weight (kg)</label>
        <input
          type="number"
          id="weightKg"
          name="weightKg"
          class="settings-input"
          value="<%= profile && profile.weight_kg ? profile.weight_kg : '' %>"
          placeholder="e.g. 70"
          min="10"
          max="500"
          step="0.1"
        >
      </div>
    </div>

    <button type="submit" class="btn-settings-save">Save changes</button>
  </form>
</div>

<%- include('../partials/bottomNav') %>
