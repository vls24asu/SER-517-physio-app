<div class="onboarding-wrapper">
  <div class="phone-card">

    <!-- Progress Capsules -->
    <div class="progress-capsules">
      <div class="capsule"></div>
      <div class="capsule"></div>
      <div class="capsule"></div>
      <div class="capsule"></div>
      <div class="capsule"></div>
      <div class="capsule"></div>
    </div>

    <form method="POST" action="/onboarding/complete">

      <!-- STEP 1 -->
      <div class="step">
        <h4>Body metrics</h4>
        <p class="subtitle">This helps us personalize your experience</p>

        <div class="mb-3">
          <label>Height</label>
          <input type="number" class="form-control" name="height">
        </div>

        <div class="mb-3">
          <label>Weight</label>
          <input type="number" class="form-control" name="weight">
        </div>

        <div class="btn-row">
          <span></span>
          <button type="button" class="btn btn-yellow next-btn">Continue</button>
        </div>
      </div>

      <!-- STEP 2 -->
      <div class="step">
        <h4>Pain assessment</h4>
        <p>Do you currently have pain?</p>

        <div class="select-card">Yes, I have pain</div>
        <div class="select-card">No pain</div>

        <div class="btn-row">
          <button type="button" class="btn btn-outline-secondary prev-btn">Back</button>
          <button type="button" class="btn btn-yellow next-btn">Continue</button>
        </div>
      </div>

      <!-- STEP 3 -->
      <div class="step">
        <h4>What’s your goal?</h4>

        <div class="select-card">Build strength</div>
        <div class="select-card">Stretch & recover</div>
        <div class="select-card">Improve mobility</div>

        <div class="btn-row">
          <button type="button" class="btn btn-outline-secondary prev-btn">Back</button>
          <button type="button" class="btn btn-yellow next-btn">Continue</button>
        </div>
      </div>

      <!-- STEP 4 -->
      <div class="step">
        <h4>Activity Level</h4>

        <div class="select-card">Beginner</div>
        <div class="select-card">Intermediate</div>
        <div class="select-card">Advanced</div>

        <div class="btn-row">
          <button type="button" class="btn btn-outline-secondary prev-btn">Back</button>
          <button type="button" class="btn btn-yellow next-btn">Continue</button>
        </div>
      </div>

      <!-- STEP 5 -->
      <div class="step">
        <h4>What equipment do you have?</h4>

        <div class="select-card">Resistance bands</div>
        <div class="select-card">Dumbbells</div>
        <div class="select-card">Yoga mat</div>

        <div class="btn-row">
          <button type="button" class="btn btn-outline-secondary prev-btn">Back</button>
          <button type="submit" class="btn btn-yellow">Create my plan</button>
        </div>
      </div>

    </form>
  </div>
</div>

<style>
.onboarding-wrapper {
  background: #F6F1E8;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
}

.phone-card {
  width: 380px;
  background: #fff;
  border-radius: 20px;
  padding: 25px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.08);
}

.progress-capsules {
  display: flex;
  gap: 6px;
  margin-bottom: 20px;
}

.capsule {
  flex: 1;
  height: 6px;
  background: #E0E0E0;
  border-radius: 10px;
}

.capsule.active {
  background: #E7B04A;
}

.subtitle {
  color: #777;
  margin-bottom: 20px;
}

.select-card {
  padding: 12px;
  border-radius: 12px;
  border: 1px solid #ddd;
  margin-bottom: 10px;
  cursor: pointer;
}

.select-card.active {
  border-color: #E7B04A;
  background: #FFF6E4;
}

.btn-yellow {
  background: #E7B04A;
  border: none;
  color: #000;
}

.btn-yellow:hover {
  background: #d89c2f;
}

.btn-row {
  display: flex;
  justify-content: space-between;
  margin-top: 20px;
}

.step {
  display: none;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const steps = document.querySelectorAll(".step");
  const capsules = document.querySelectorAll(".capsule");
  const nextBtns = document.querySelectorAll(".next-btn");
  const prevBtns = document.querySelectorAll(".prev-btn");
  const cards = document.querySelectorAll(".select-card");

  let currentStep = 0;

  function updateStep() {
    steps.forEach((step, i) => {
      step.style.display = i === currentStep ? "block" : "none";
    });

    capsules.forEach((c, i) => {
      c.classList.toggle("active", i <= currentStep);
    });
  }

  nextBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      if (currentStep < steps.length - 1) {
        currentStep++;
        updateStep();
      }
    });
  });

  prevBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      if (currentStep > 0) {
        currentStep--;
        updateStep();
      }
    });
  });

  cards.forEach(card => {
    card.addEventListener("click", function () {
      if (!this.parentElement.classList.contains("multi")) {
        this.parentElement.querySelectorAll(".select-card")
          .forEach(c => c.classList.remove("active"));
      }
      this.classList.toggle("active");
    });
  });

  updateStep();
});
</script>