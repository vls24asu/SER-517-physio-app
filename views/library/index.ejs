<%
  const categoryLabelMap = {
    strengthen: 'Strengthen',
    stretch: 'Stretch',
    avoid: 'Avoid'
  };

  const categoryEmojiMap = {
    strengthen: '💪',
    stretch: '🧘',
    avoid: '⚠️'
  };
%>

<div class="library-container">
  <div class="library-header">
    <h1 class="library-title">Exercise Library</h1>
    <p class="library-subtitle">Browse all workouts and programs</p>
  </div>

  <form action="/library" method="GET" class="library-search-form" role="search" id="librarySearchForm">
    <div class="library-search-input-wrap" style="position: relative;">
      <i class="bi bi-search library-search-icon" aria-hidden="true"></i>
      <input
        type="text"
        name="search"
        id="librarySearchInput"
        class="library-search-input"
        placeholder="Search exercises..."
        value="<%= searchQuery %>"
        aria-label="Search exercises"
        autocomplete="off"
      >
      <% if (activeCategory && activeCategory !== 'all') { %>
        <input type="hidden" name="category" value="<%= activeCategory %>">
      <% } %>
      <ul id="searchSuggestions" style="
        display: none;
        position: absolute;
        top: 100%;
        left: 0; right: 0;
        background: #fff;
        border: 1px solid #E0D3BE;
        border-radius: 12px;
        margin-top: 4px;
        padding: 4px 0;
        list-style: none;
        z-index: 100;
        box-shadow: 0 4px 16px rgba(0,0,0,0.08);
      "></ul>
    </div>
  </form>

  <script>
    (function () {
      const input = document.getElementById('librarySearchInput');
      const list  = document.getElementById('searchSuggestions');
      let debounceTimer;

      const categoryEmoji = { strengthen: '💪', stretch: '🧘', avoid: '⚠️' };

      input.addEventListener('input', function () {
        clearTimeout(debounceTimer);
        const q = this.value.trim();
        if (q.length < 2) { list.style.display = 'none'; return; }

        debounceTimer = setTimeout(async () => {
          try {
            const res  = await fetch('/library/suggestions?q=' + encodeURIComponent(q));
            const data = await res.json();
            list.innerHTML = '';
            if (data.length === 0) { list.style.display = 'none'; return; }

            data.forEach(ex => {
              const li = document.createElement('li');
              li.style.cssText = 'padding: 10px 16px; cursor: pointer; display: flex; align-items: center; gap: 10px; font-size: 14px;';
              li.innerHTML = '<span>' + (categoryEmoji[ex.category] || '🏋️') + '</span><span>' + ex.name + '</span>';
              li.addEventListener('mousedown', () => {
                window.location.href = '/library/' + ex.id;
              });
              li.addEventListener('mouseover', () => li.style.background = '#FAF6EE');
              li.addEventListener('mouseout',  () => li.style.background = '');
              list.appendChild(li);
            });
            list.style.display = 'block';
          } catch (e) { list.style.display = 'none'; }
        }, 250);
      });

      document.addEventListener('click', function (e) {
        if (!input.contains(e.target)) list.style.display = 'none';
      });
    })();
  </script>

  <div class="library-filter-tabs" role="tablist" aria-label="Exercise categories">
    <a
      href="/library?category=all"
      class="library-filter-tab <%= activeCategory === 'all' ? 'active' : '' %>"
      aria-current="<%= activeCategory === 'all' ? 'page' : 'false' %>"
    >
      All
    </a>
    <a
      href="/library?category=strengthen"
      class="library-filter-tab <%= activeCategory === 'strengthen' ? 'active' : '' %>"
      aria-current="<%= activeCategory === 'strengthen' ? 'page' : 'false' %>"
    >
      Upper body
    </a>
    <a
      href="/library?category=stretch"
      class="library-filter-tab <%= activeCategory === 'stretch' ? 'active' : '' %>"
      aria-current="<%= activeCategory === 'stretch' ? 'page' : 'false' %>"
    >
      Lower body
    </a>
  </div>

  <% if (searchQuery) { %>
    <p class="library-results-meta">
      Showing results for "<strong><%= searchQuery %></strong>"
    </p>
  <% } %>

  <% if (!exercises || exercises.length === 0) { %>
    <div class="library-empty-state">
      <div class="library-empty-emoji" aria-hidden="true">🔎</div>
      <h2 class="library-empty-title">No exercises found</h2>
      <p class="library-empty-text">
        Try a different search term or browse all exercises in the library.
      </p>
      <a href="/library" class="btn btn-start-session library-empty-btn">Browse Library</a>
    </div>
  <% } else { %>
    <div class="exercise-grid">
      <% exercises.forEach(exercise => { %>
        <a href="/library/<%= exercise.id %>" class="exercise-card">
          <div class="exercise-card-top">
            <div class="exercise-emoji" aria-hidden="true">
              <%= categoryEmojiMap[exercise.category] || '🏋️' %>
            </div>
            <span class="exercise-tag">
              <%= categoryLabelMap[exercise.category] || exercise.category %>
            </span>
          </div>

          <div class="exercise-card-content">
            <h3 class="exercise-card-title"><%= exercise.name %></h3>
            <p class="exercise-card-meta">
              <%= exercise.sets || 0 %> sets
              <% if (exercise.skill_level) { %>
                • <%= exercise.skill_level %>
              <% } %>
            </p>
          </div>
        </a>
      <% }); %>
    </div>
  <% } %>
</div>

<%- include('../partials/bottomNav') %>
