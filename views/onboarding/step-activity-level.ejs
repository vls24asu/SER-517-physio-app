<!-- STEP 5: Activity level -->
<div class="step">
  <h4 class="step-title">Activity Level</h4>
  <p class="subtitle">How active are you currently?</p>

  <div class="stacked-cards">
    <div class="select-card" data-name="activity_level" data-value="beginner">
      <div class="select-card-content">
        <span class="emoji">🚶</span>
        <div>
          <div class="card-title">Beginner</div>
          <div class="card-subtitle">Little to no regular exercise</div>
        </div>
      </div>
    </div>
    <div class="select-card" data-name="activity_level" data-value="intermediate">
      <div class="select-card-content">
        <span class="emoji">🏃</span>
        <div>
          <div class="card-title">Intermediate</div>
          <div class="card-subtitle">Exercise 2–3 times per week</div>
        </div>
      </div>
    </div>
    <div class="select-card" data-name="activity_level" data-value="advanced">
      <div class="select-card-content">
        <span class="emoji">🏋️</span>
        <div>
          <div class="card-title">Advanced</div>
          <div class="card-subtitle">Intense workouts 4+ times per week</div>
        </div>
      </div>
    </div>
  </div>

  <div class="mb-3 mt-3">
    <label class="field-label">Preferred session duration</label>
    <div class="select-wrapper">
      <select class="form-select" name="session_duration">
        <option value="15-20">15–20 minutes</option>
        <option value="20-30">20–30 minutes</option>
        <option value="30-45">30–45 minutes</option>
      </select>
    </div>
  </div>

  <div class="btn-row">
    <button type="button" class="btn btn-outline-secondary rounded-pill px-4 prev-btn">Back</button>
    <button type="button" class="btn btn-yellow next-btn">Continue</button>
  </div>
</div>

