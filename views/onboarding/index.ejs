<div class="onboarding-wrapper">
  <div class="phone-card">

    <!-- Progress Capsules -->
    <div class="progress-capsules">
      <div class="capsule"></div>
      <div class="capsule"></div>
      <div class="capsule"></div>
      <div class="capsule"></div>
      <div class="capsule"></div>
      <div class="capsule"></div>
      <div class="capsule"></div>
    </div>

    <form method="POST" action="/onboarding/complete">

      <%- include('step-body-metrics') %>
      <%- include('step-pain-assessment') %>
      <%- include('step-pain-intensity') %>
      <%- include('step-goal') %>
      <%- include('step-activity-level') %>
      <%- include('step-equipment') %>
      <%- include('step-profile-live') %>

      <!-- Hidden inputs for card selections -->
      <div id="onboardingHiddenFields"></div>

    </form>
  </div>
</div>

<style>
.onboarding-wrapper {
  background: #FCF7EE;
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding: 40px 25px;
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.phone-card {
  width: 100%;
  max-width: 480px;
  background: transparent;
  border-radius: 0;
  padding: 0;
}

.progress-capsules {
  display: flex;
  gap: 6px;
  margin-bottom: 24px;
}

.capsule {
  flex: 1;
  height: 6px;
  background: #E0E0E0;
  border-radius: 999px;
}

.capsule.active {
  background: #E7B04A;
}

.step-title {
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 4px;
}

.subtitle {
  color: #7A7A7A;
  font-size: 13px;
  margin-bottom: 18px;
}

.field-label {
  display: block;
  font-size: 13px;
  font-weight: 500;
  margin-bottom: 6px;
  color: #333;
}

.fancy-input {
  border-radius: 12px;
  border: 1px solid #E0E0E0;
  padding: 10px 12px;
  font-size: 14px;
}

.fancy-input:focus {
  border-color: #E7B04A;
  box-shadow: 0 0 0 2px rgba(231,176,74,0.25);
}

.select-wrapper {
  border-radius: 12px;
  border: 1px solid #E0E0E0;
  overflow: hidden;
  background-color: #ffffff;
}

.select-wrapper .form-select {
  border: none;
  box-shadow: none;
  padding: 8px 10px;
  font-size: 14px;
  width: 100%;
  background-color: transparent;
}

.select-card {
  padding: 12px 14px;
  border-radius: 14px;
  border: 1px solid #E4E1DB;
  margin-bottom: 10px;
  cursor: pointer;
  background: #fff;
  transition: border-color 0.18s ease, background-color 0.18s ease, box-shadow 0.18s ease;
  display: flex;
  align-items: center;
  gap: 8px;
}

.select-card-content {
  display: flex;
  align-items: center;
  gap: 10px;
}

.select-card .emoji {
  font-size: 18px;
}

.select-card.active {
  border-color: #E7B04A;
  background: #FFF6E4;
  box-shadow: 0 5px 10px rgba(231,176,74,0.18);
}

.select-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.select-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.stacked-cards .select-card {
  margin-bottom: 12px;
}

.card-title {
  font-size: 14px;
  font-weight: 600;
}

.card-subtitle {
  font-size: 12px;
  color: #7A7A7A;
}

.dual-fields {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
}

.dual-input {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 8px;
  align-items: center;
}

.unit-select .form-select {
  text-align: center;
}

.btn-yellow {
  background: #E7B04A;
  border: none;
  color: #000;
  font-weight: 600;
  border-radius: 999px;
  padding-inline: 28px;
}

.btn-yellow:hover {
  background: #d89c2f;
}

.btn-outline-secondary {
  background-color: #fff;
  color: #000;
  border-radius: 999px;
  border: 1px solid #222;
  font-weight: 500;
  padding-inline: 24px;
}

.btn-outline-secondary:hover {
  background-color: #f5f1ea;
  color: #000;
  border-color: #222;
}

.btn-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24px;
  gap: 10px;
}

.btn-row .btn {
  height: 42px;
}

.step {
  display: none;
}

.text-center {
  text-align: center;
}

.mt-3 {
  margin-top: 1rem;
}

.mb-3 {
  margin-bottom: 1rem;
}

.w-100 {
  width: 100%;
}

.info-box {
  border-radius: 12px;
  padding: 10px 12px;
  background: #E8F2FF;
  color: #2F4E7A;
  font-size: 12px;
  margin-top: 18px;
}

.pain-slider {
  width: 100%;
  accent-color: #E7B04A;
}

.range-labels {
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: #7A7A7A;
  margin-top: 4px;
}

.success-header {
  display: flex;
  justify-content: center;
  margin-bottom: 32px;
}

.logo-placeholder {
  width: 72px;
  height: 72px;
  border-radius: 999px;
  border: 2px dashed #E0D3BE;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  color: #9C8B70;
}

.success-body {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.success-card {
  background: #ffffff;
  border-radius: 20px;
  padding: 20px 20px 22px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.06);
}

.success-card .btn-yellow {
  width: 80%;
  border-radius: 999px;
  display: block;
  margin: 4px auto 0;
  padding-top: 10px;
  padding-bottom: 10px;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const steps = document.querySelectorAll(".step");
  const capsules = document.querySelectorAll(".capsule");
  const nextBtns = document.querySelectorAll(".next-btn");
  const prevBtns = document.querySelectorAll(".prev-btn");
  const cards = document.querySelectorAll(".select-card");
  const hiddenFieldsContainer = document.getElementById("onboardingHiddenFields");
  const painRange = document.getElementById("painIntensityRange");
  const painLevelValue = document.getElementById("painLevelValue");

  let currentStep = 0;

  function updateStep() {
    steps.forEach((step, i) => {
      step.style.display = i === currentStep ? "block" : "none";
    });

    capsules.forEach((c, i) => {
      c.classList.toggle("active", i <= currentStep);
    });
  }

  function syncHiddenFields() {
    hiddenFieldsContainer.innerHTML = "";

    const selections = {};

    cards.forEach(card => {
      if (card.classList.contains("active")) {
        const name = card.getAttribute("data-name");
        const value = card.getAttribute("data-value");
        if (!name || !value) return;

        if (!selections[name]) {
          selections[name] = [];
        }
        selections[name].push(value);
      }
    });

    Object.keys(selections).forEach(name => {
      selections[name].forEach(value => {
        const input = document.createElement("input");
        input.type = "hidden";
        input.name = name.endsWith("[]") ? name : name + (selections[name].length > 1 ? "[]" : "");
        input.value = value;
        hiddenFieldsContainer.appendChild(input);
      });
    });
  }

  nextBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      if (currentStep < steps.length - 1) {
        currentStep++;
        updateStep();
        syncHiddenFields();
      }
    });
  });

  prevBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      if (currentStep > 0) {
        currentStep--;
        updateStep();
        syncHiddenFields();
      }
    });
  });

  cards.forEach(card => {
    card.addEventListener("click", function () {
      const parentIsMulti = this.parentElement.classList.contains("multi");
      const name = this.getAttribute("data-name");
      if (!parentIsMulti && name) {
        document
          .querySelectorAll('.select-card[data-name="' + name + '"]')
          .forEach(c => c.classList.remove("active"));
      }
      this.classList.toggle("active");
      syncHiddenFields();
    });
  });

  if (painRange && painLevelValue) {
    const updatePainText = () => {
      painLevelValue.textContent = painRange.value + "/10";
    };
    painRange.addEventListener("input", updatePainText);
    updatePainText();
  }

  updateStep();
});
</script>

