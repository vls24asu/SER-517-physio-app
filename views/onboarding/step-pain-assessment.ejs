<!-- STEP 2: Pain assessment + areas -->
<div class="step">
  <h4 class="step-title">Pain assessment</h4>
  <p class="subtitle">Do you currently have any pain or discomfort?</p>

  <div class="select-row">
    <div class="select-card" data-name="pain_status" data-value="yes">
      <div class="select-card-content">
        <span class="emoji">😣</span>
        <span>Yes, I have pain</span>
      </div>
    </div>
    <div class="select-card" data-name="pain_status" data-value="no">
      <div class="select-card-content">
        <span class="emoji">🙂</span>
        <span>No pain</span>
      </div>
    </div>
  </div>

  <p class="field-label mt-3">Where does it hurt?</p>
  <div class="select-grid multi">
    <div class="select-card" data-name="pain_areas" data-value="neck">
      <span>🛠️</span>
      <span>Neck</span>
    </div>
    <div class="select-card" data-name="pain_areas" data-value="back">
      <span>🧍</span>
      <span>Back</span>
    </div>
    <div class="select-card" data-name="pain_areas" data-value="shoulders">
      <span>💪</span>
      <span>Shoulders</span>
    </div>
    <div class="select-card" data-name="pain_areas" data-value="knees">
      <span>🦵</span>
      <span>Knees</span>
    </div>
  </div>

  <div class="btn-row">
    <button type="button" class="btn btn-outline-secondary rounded-pill px-4 prev-btn">Back</button>
    <button type="button" class="btn btn-yellow next-btn">Continue</button>
  </div>
</div>

