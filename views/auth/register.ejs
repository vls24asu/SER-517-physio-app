<div class="row justify-content-center flex-grow-1">
  <div class="col-md-5 col-lg-4 d-flex flex-column">

    <!-- Progress bar -->
    <div class="d-flex gap-2 mb-4 mt-3">
      <div class="flex-fill rounded-pill" style="height: 6px; background-color: #F5A623;"></div>
      <div class="flex-fill rounded-pill" style="height: 6px; background-color: #e0e0e0;"></div>
      <div class="flex-fill rounded-pill" style="height: 6px; background-color: #e0e0e0;"></div>
      <div class="flex-fill rounded-pill" style="height: 6px; background-color: #e0e0e0;"></div>
      <div class="flex-fill rounded-pill" style="height: 6px; background-color: #e0e0e0;"></div>
      <div class="flex-fill rounded-pill" style="height: 6px; background-color: #e0e0e0;"></div>
    </div>

    <h2 class="fw-bold mb-1">Create account</h2>
    <p class="text-muted mb-3">Let's get you set up</p>

    <!-- Error messages -->
    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% errors.forEach(err => { %>
          <div><%= err.msg %></div>
        <% }) %>
      </div>
    <% } %>

    <form action="/register" method="POST" class="d-flex flex-column flex-grow-1">

      <!-- Full Name -->
      <div class="mb-3">
        <label for="fullName" class="form-label">Full Name</label>
        <input type="text" class="form-control" id="fullName" name="fullName" placeholder="Enter your name" value="<%= typeof fullName !== 'undefined' ? fullName : '' %>" required>
      </div>

      <!-- Email -->
      <div class="mb-3">
        <label for="email" class="form-label">Email address</label>
        <input type="email" class="form-control" id="email" name="email" placeholder="your.email@example.com" value="<%= typeof email !== 'undefined' ? email : '' %>" required>
      </div>

      <!-- Password -->
      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <div class="input-group">
          <input type="password" class="form-control" id="password" name="password" placeholder="Create a password" required>
          <button class="btn btn-outline-secondary" type="button" id="togglePassword">
            <i class="bi bi-eye"></i>
          </button>
        </div>
        <div class="pw-rules mt-2" id="pwRules">
          <p class="pw-rule" id="rule-length"><i class="bi bi-x-circle-fill"></i> At least 8 characters</p>
          <p class="pw-rule" id="rule-upper"><i class="bi bi-x-circle-fill"></i> One uppercase letter</p>
          <p class="pw-rule" id="rule-lower"><i class="bi bi-x-circle-fill"></i> One lowercase letter</p>
          <p class="pw-rule" id="rule-special"><i class="bi bi-x-circle-fill"></i> One special character (!@#$...)</p>
        </div>
      </div>

      <!-- Terms -->
      <div class="form-check mb-3">
        <input type="checkbox" class="form-check-input" id="terms" name="terms" required>
        <label class="form-check-label" for="terms">
          I agree to the <a href="#" class="text-warning">Terms of Service</a> and <a href="#" class="text-warning">Privacy Policy</a>
        </label>
      </div>

      <!-- Spacer pushes button to bottom -->
      <div class="flex-grow-1"></div>

      <!-- Submit -->
      <button type="submit" class="btn w-100 fw-semibold py-2 rounded-pill" style="background-color: #F5A623; color: #000;">
        Create account
      </button>

      <p class="text-center mt-3">
        Already have an account? <a href="/login" class="text-warning">Log in</a>
      </p>

    </form>

  </div>
</div>

<script>
  // Password complexity rules
  const passwordInput = document.getElementById('password');
  const rules = {
    'rule-length':  v => v.length >= 8,
    'rule-upper':   v => /[A-Z]/.test(v),
    'rule-lower':   v => /[a-z]/.test(v),
    'rule-special': v => /[!@#$%^&*(),.?":{}|<>]/.test(v),
  };

  passwordInput.addEventListener('input', () => {
    const v = passwordInput.value;
    Object.entries(rules).forEach(([id, test]) => {
      const el = document.getElementById(id);
      const icon = el.querySelector('i');
      if (test(v)) {
        el.classList.add('pw-rule--pass');
        icon.className = 'bi bi-check-circle-fill';
      } else {
        el.classList.remove('pw-rule--pass');
        icon.className = 'bi bi-x-circle-fill';
      }
    });
  });

  document.getElementById('togglePassword').addEventListener('click', function () {
    const input = document.getElementById('password');
    const icon = this.querySelector('i');
    if (input.type === 'password') {
      input.type = 'text';
      icon.classList.replace('bi-eye', 'bi-eye-slash');
    } else {
      input.type = 'password';
      icon.classList.replace('bi-eye-slash', 'bi-eye');
    }
  });
</script>
